<%- include("partials/header", {
    pageTitle: "Tehtud tööd – geelküüned ja iluteenused",
    pageDescription: "Vaata meie tehtud töid – geelküüned ja muud iluteenused Mustamäel.",
    canonicalUrl: "https://iluteenused.com/tehtudtood",
    ogTitle: "Tehtud tööd – geelküüned",
    ogDescription: "Galerii tehtud töödest Mustamäel.",
    activePage: "tehtudtood"
}) %>

<section class="gallery-section" id="kuuned">
    <h1 class="info-title">TEHTUD TÖÖD</h1>
    <h2 class="gallery-title">Küüned</h2>

    <% if (kuuned.length > 0) { %>
        <div class="gallery-grid">
            <% kuuned.forEach(image => { %>
                <div class="gallery-card">
                    <button
                        class="gallery-image-button"
                        type="button"
                        onclick="openLightbox('<%= image %>')"
                        aria-label="Ava pilt suurelt"
                    >
                        <img src="<%= image %>" alt="Küüned">
                        <span class="gallery-overlay">Vaata pilti</span>
                    </button>
                </div>
            <% }) %>
        </div>
    <% } else { %>
        <p class="gallery-empty">Hetkel pole küünte pilte lisatud.</p>
    <% } %>
</section>

<section class="gallery-section" id="juuksed">
    <h2 class="gallery-title">Juuksed</h2>

    <% if (juuksed.length > 0) { %>
        <div class="gallery-grid">
            <% juuksed.forEach(image => { %>
                <div class="gallery-card">
                    <button
                        class="gallery-image-button"
                        type="button"
                        onclick="openLightbox('<%= image %>')"
                        aria-label="Ava pilt suurelt"
                    >
                        <img src="<%= image %>" alt="Juuksed">
                        <span class="gallery-overlay">Vaata pilti</span>
                    </button>
                </div>
            <% }) %>
        </div>
    <% } else { %>
        <p class="gallery-empty">Hetkel pole juuste pilte lisatud.</p>
    <% } %>
</section>


<div id="lightbox" class="lightbox" onclick="closeLightbox(event)">
    <button class="lightbox-close" type="button" onclick="closeLightbox()" aria-label="Sulge pilt">
        ×
    </button>
    <img id="lightbox-image" class="lightbox-image" src="" alt="Suur pilt">
</div>



<script>
    function openLightbox(imageSrc) {
        const lightbox = document.getElementById("lightbox");
        const lightboxImage = document.getElementById("lightbox-image");

        lightboxImage.src = imageSrc;
        lightbox.classList.add("active");
        document.body.classList.add("no-scroll");
    }

    function closeLightbox(event) {
        const lightbox = document.getElementById("lightbox");

        if (!event || event.target.id === "lightbox" || event.target.classList.contains("lightbox-close")) {
            lightbox.classList.remove("active");
            document.getElementById("lightbox-image").src = "";
            document.body.classList.remove("no-scroll");
        }
    }

    document.addEventListener("keydown", function (event) {
        if (event.key === "Escape") {
            const lightbox = document.getElementById("lightbox");
            if (lightbox.classList.contains("active")) {
                lightbox.classList.remove("active");
                document.getElementById("lightbox-image").src = "";
                document.body.classList.remove("no-scroll");
            }
        }
    });
</script>

<%- include("partials/footer") %>
