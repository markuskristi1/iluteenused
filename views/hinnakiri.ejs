<%- include("partials/header", {
    pageTitle: "Hinnakiri – geelküüned ja iluteenused Mustamäel",
    pageDescription: "Vaata iluteenuste hinnakirja Mustamäel – geelküüned, geellakkimine, kõrvaaukude tegemine ja muud teenused.",
    canonicalUrl: "https://iluteenused.com/hinnakiri",
    ogTitle: "Iluteenuste hinnakiri Mustamäel",
    ogDescription: "Geelküünte ja teiste iluteenuste hinnad Mustamäel.",
    activePage: "hinnakiri"
}) %>

<section class="price-section">
    <h1 class="price-title">HINNAKIRI</h1>

    <% categories.forEach((category, index) => { %>
        <% const safeGroups = category.groups || []; %>
        <% const safeItems = category.items || []; %>

        <% if (index > 0) { %>
            <div class="price-divider"></div>
        <% } %>

        <div id="<%= category.id %>" class="section-anchor"></div>
        <div class="price-category"><%= category.title %></div>

        <% if (safeGroups.length > 0) { %>
            <% safeGroups.forEach(group => { %>
                <% const groupItems = group.items || []; %>

                <% if (groupItems.length > 0) { %>
                    <div class="price-subcategory"><%= group.title %></div>

                    <div class="price-list">
                        <% groupItems.forEach(item => { %>
                            <div class="price-row">
                                <div>
                                    <span class="service"><%= item.name %></span>
                                    <% if (item.description) { %>
                                        <p class="price-desc"><%= item.description %></p>
                                    <% } %>
                                </div>

                                <% if (item.price) { %>
                                    <span class="price"><%= item.price %></span>
                                <% } %>
                            </div>
                        <% }) %>
                    </div>
                <% } %>
            <% }) %>
        <% } else if (safeItems.length > 0) { %>
            <div class="price-list">
                <% safeItems.forEach(item => { %>
                    <div class="price-row">
                        <div>
                            <span class="service"><%= item.name %></span>
                            <% if (item.description) { %>
                                <p class="price-desc"><%= item.description %></p>
                            <% } %>
                        </div>

                        <% if (item.price) { %>
                            <span class="price"><%= item.price %></span>
                        <% } %>
                    </div>
                <% }) %>
            </div>
        <% } %>

        <% if (category.notes && category.notes.length > 0) { %>
            <div class="nail-note">
                <% category.notes.forEach(note => { %>
                    <p><%= note %></p>
                <% }) %>
            </div>
        <% } %>
    <% }) %>
</section>

<%- include("partials/footer") %>