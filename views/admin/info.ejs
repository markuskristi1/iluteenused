<%- include("partials/header", { pageTitle: "Info", activePage: "info" }) %>

<section class="info-section">
    <h1 class="info-title">INFO (ADMIN)</h1>

    <% if (message) { %>
        <div class="success-message"><%= message %></div>
    <% } %>

    <div class="info-block">
        <h2>Lisa uus info</h2>

        <form method="POST" action="/admin/info/add" class="admin-form">
            <label for="title">Pealkiri</label>
            <input type="text" id="title" name="title" required>

            <label for="content">Sisu</label>
            <textarea id="content" name="content" rows="8" required></textarea>

            <label for="sort_order">Järjekord</label>
            <input type="number" id="sort_order" name="sort_order" value="1" required>

            <button type="submit" class="btn">Lisa info</button>
        </form>
    </div>

    <% infoItems.forEach(item => { %>
        <div class="info-block admin-category-group">
            <h2><%= item.title %></h2>

            <div class="admin-item-form">
                <form method="POST" action="/admin/info/<%= item.id %>/update" class="admin-form">
                    <label>Pealkiri</label>
                    <input type="text" name="title" value="<%= item.title %>" required>

                    <label>Sisu</label>
                    <textarea name="content" rows="8" required><%= item.content || '' %></textarea>

                    <label>Järjekord</label>
                    <input type="number" name="sort_order" value="<%= item.sort_order %>" required>

                    <div class="admin-actions">
                        <button type="submit" class="btn">Salvesta</button>
                    </div>
                </form>

                <form method="POST" action="/admin/info/<%= item.id %>/delete" onsubmit="return confirm('Kas kustutada see info?')">
                    <button type="submit" class="btn btn-delete">Kustuta</button>
                </form>
            </div>
        </div>
    <% }) %>
</section>

<%- include("partials/footer") %>