<%- include("partials/header", {
    pageTitle: "Geelküüned Mustamäel – kõrvaaukude tegemine ja keratiin juuste sirgendamine",
    pageDescription: "Geelküüned, kõrvaaukude tegemine ja keratiin juuste sirgendamine Mustamäel. Hubane iluteenuste stuudio Tallinnas – broneeri aeg.",
    canonicalUrl: "https://iluteenused.com/",
    ogTitle: "Geelküüned ja kõrvaaukude tegemine Mustamäel",
    ogDescription: "Geelküüned, kõrvaaukude tegemine ja keratiin juuste sirgendamine Mustamäel.",
    activePage: "avaleht"
}) %>

<section class="hero hero-slider">
    <div class="slides">
        <% if (sliderImages && sliderImages.length > 0) { %>
            <% sliderImages.forEach((image, index) => { %>
                <img
                    src="<%= image %>"
                    class="slide <%= index === 0 ? 'active' : '' %>"
                    alt="Iluteenused"
                >
            <% }) %>
        <% } else { %>
            <div class="hero-fallback"></div>
        <% } %>
    </div>

    <div class="hero-content">
        <p class="hero-subtitle">Professionaalsed iluteenused Tallinnas</p>
        <h1>ILUTEENUSED</h1>
        <a href="/kontakt" class="btn">Võta ühendust</a>
    </div>
</section>

<section class="home-intro">
    <div class="home-intro-card">
        <h2>Iluteenused Mustamäel</h2>
        <p>
            Pakume erinevaid iluteenuseid Tallinnas, Mustamäel – geelküüned, geellakkimine,
            kõrvaaukude tegemine ja Cocoshoko keratin juuste sirgendamine. Naiste- ja meestejuuksur.
            Rahulik ja hubane keskkond, kus iga klient saab personaalse ja hooliva lähenemise.
        </p>
        <a href="/hinnakiri" class="btn intro-btn">
            Tutvu meie teenuste ja hinnakirjaga
        </a>
    </div>
</section>

<section class="preview">
    <h2>Tehtud tööd</h2>

    <% if (previewImages && previewImages.length > 0) { %>
        <div class="preview-grid">
            <% previewImages.forEach(image => { %>
                <a href="/tehtudtood" class="preview-card">
                    <img src="<%= image %>" alt="Tehtud töö">
                </a>
            <% }) %>
        </div>

        <a href="/tehtudtood" class="btn">Vaata rohkem</a>
    <% } else { %>
        <p class="gallery-empty">Pildivalik lisandub peagi.</p>
    <% } %>
</section>

<%- include("partials/footer") %>